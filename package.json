{
  "name": "impactis-server",
  "version": "0.1.0",
  "description": "NestJS backend for Impactis – central business logic, authorization, and API over Postgres and Cloudflare R2.",
  "private": true,
  "scripts": {
    "dev": "npm run start:dev",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run build",
    "db:migrate:local": "node scripts/migrate-local.js",
    "db:seed:demo": "node scripts/seed-demo.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/s3-request-presigner": "^3.637.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/websockets": "^11.0.0",
    "@prisma/client": "^7.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "jose": "^6.2.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.17.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.15.6",
    "eslint": "^9.15.0",
    "prisma": "^7.4.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
