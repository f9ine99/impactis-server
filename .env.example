PORT=4000
WEB_ORIGIN=http://localhost:3000
HTTP_REQUEST_LOGGING=true

# Postgres connection (local Postgres for dev/staging)
DATABASE_URL=postgresql://admin:password1@localhost:5432/impactis
DB_APPLICATION_NAME=impactis_api
DB_QUERY_TAG=impactis_api
DB_QUERY_TELEMETRY_ENABLED=false
DB_QUERY_TELEMETRY_FLUSH_INTERVAL_MS=60000
DB_SLOW_QUERY_THRESHOLD_MS=120
DB_SCHEMA_CHECK_CACHE_TTL_MS=300000

# Cloudflare R2 (for pitch decks, documents, attachments)
R2_ACCOUNT_ID=YOUR_R2_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=impactis-files

# Optional: public URL for serving files (CDN / custom domain)
R2_PUBLIC_BASE_URL=https://files.impactis.local

# Optional: comma-separated emails allowed to access /api/v1/admin/readiness
ADMIN_USER_EMAILS=admin@example.com

# Upstash Redis (optional cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_WORKSPACE_BOOTSTRAP_TTL_SECONDS=300
CACHE_WORKSPACE_IDENTITY_TTL_SECONDS=300
CACHE_WORKSPACE_SETTINGS_TTL_SECONDS=300
CACHE_WORKSPACE_EMPTY_TTL_SECONDS=30
CACHE_TTL_JITTER_PERCENT=8
CACHE_LOCK_TTL_SECONDS=5
CACHE_LOCK_WAIT_MS=80
CACHE_L1_TTL_SECONDS=60
CACHE_L1_MAX_ENTRIES=5000
CACHE_TELEMETRY_ENABLED=false
CACHE_TELEMETRY_FLUSH_INTERVAL_MS=60000
CACHE_UPSTASH_REQUEST_TIMEOUT_MS=700
CACHE_UPSTASH_FAILURE_COOLDOWN_MS=5000
CACHE_UPSTASH_FAILURE_COOLDOWN_MAX_MS=60000
CACHE_DEBUG=false
CACHE_KEY_PREFIX=impactis


