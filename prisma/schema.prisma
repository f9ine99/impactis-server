  users_startup_posts_created_byTousers users?              @relation("startup_posts_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  organizations                         organizations       @relation(fields: [startup_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_startup_posts_updated_byTousers users?              @relation("startup_posts_updated_byTousers", fields: [updated_by], references: [id], onUpdate: NoAction)

  @@index([industry_tags], type: Gin)
  @@index([status, published_at(sort: Desc)], map: "startup_posts_status_published_idx")
  @@index([need_advisor, status], map: "startup_posts_need_advisor_status_idx", where: raw("(need_advisor = true AND status = 'published'::public.startup_post_status)"))
  @@schema("public")
}

